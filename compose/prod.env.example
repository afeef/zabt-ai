# ============================================================
# Zabt — Production environment file (VPS)
# Copy this file to .env at the repo root, then fill secrets.
# DO NOT commit .env to version control.
# ============================================================

# Compose file selection — picks the prod overlay only.
COMPOSE_FILE=docker-compose.yml:compose/prod.yml

# --- Database (Supabase managed Postgres via pooler) ---
DATABASE_URL=postgresql+asyncpg://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Supabase Auth ---
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard>
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>

# --- Storage — S3 ---
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=https://s3.us-east-2.amazonaws.com
S3_ACCESS_KEY_ID=<aws-access-key>
S3_SECRET_ACCESS_KEY=<aws-secret-key>
S3_BUCKET_NAME=zabt-ai-bucket
S3_PUBLIC_URL=https://s3.us-east-2.amazonaws.com
S3_REGION=us-east-2

# --- Transcription — RunPod ---
TRANSCRIPTION_BACKEND=runpod
RUNPOD_API_KEY=<runpod-api-key>
RUNPOD_ENDPOINT_ID=<runpod-endpoint-id>
RUNPOD_TIMEOUT=1800

# --- OpenAI / OpenRouter ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=<openrouter-key>
OPENAI_MODEL=google/gemini-3.1-flash-lite-preview

# --- Microsoft Integration ---
MICROSOFT_CLIENT_ID=<entra-app-client-id>
MICROSOFT_CLIENT_SECRET=<entra-app-secret>
MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI defaulted by compose/prod.yml — only override if needed.

# --- Token encryption (Fernet) ---
TOKEN_ENCRYPTION_KEY=<generate-with-Fernet.generate_key>

# --- HuggingFace ---
HF_TOKEN=<hf-token>
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Backend CORS ---
BACKEND_CORS_ORIGINS=https://app.zabt.ai,https://www.zabt.ai

# --- Email (Resend) ---
RESEND_API_KEY=<resend-key>
RESEND_FROM_EMAIL=no-reply@zabt.ai
# APP_URL defaulted by compose/prod.yml.

# --- Sentry ---
SENTRY_DSN=<backend-sentry-dsn>
# SENTRY_ENVIRONMENT defaulted to "production" by compose/prod.yml.

# --- Logfire ---
LOGFIRE_TOKEN=<logfire-token>

# --- Langfuse ---
LANGFUSE_SECRET_KEY=<langfuse-secret>
LANGFUSE_PUBLIC_KEY=<langfuse-public>
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostHog ---
POSTHOG_API_KEY=<posthog-key>
POSTHOG_HOST=https://us.i.posthog.com

# --- Notifications (Telegram) ---
NOTIFICATION_PROVIDER=multi
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_CHAT_ID=<telegram-chat-id>

# --- Bot Worker ---
BOT_WORKER_URL=http://worker-bot:8002
BOT_DISPLAY_NAME=Zabt AI Notetaker

# --- MinIO webhook (used for local; prod ignores it but keep schema) ---
MINIO_WEBHOOK_SECRET=unused-in-prod
