# ============================================================
# Zabt — Local dev environment file
# Copy to .env at the repo root, then fill secrets.
# Default stack: full standalone (local Postgres + MinIO + GPU worker).
# To swap a service for its cloud version, drop its fragment from
# COMPOSE_FILE below.
# ============================================================

# Default = full standalone. Drop fragments to swap in cloud services:
#   COMPOSE_FILE=docker-compose.yml:compose/local.yml                                   # API + frontend only (uses Supabase + S3 + RunPod from below)
#   COMPOSE_FILE=docker-compose.yml:compose/local.yml:compose/db.local.yml             # local Postgres + cloud storage + RunPod
#   COMPOSE_FILE=docker-compose.yml:compose/local.yml:compose/storage.local.yml        # cloud Postgres + local MinIO + RunPod
#   COMPOSE_FILE=docker-compose.yml:compose/local.yml:compose/gpu.local.yml            # cloud Postgres + cloud storage + local GPU
COMPOSE_FILE=docker-compose.yml:compose/local.yml:compose/db.local.yml:compose/storage.local.yml:compose/gpu.local.yml

# --- Database ---
# Set by db.local.yml when included. When dropped, set to Supabase pooler:
# DATABASE_URL=postgresql+asyncpg://postgres.<project>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Local Postgres credentials (used by db.local.yml only)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=zabt

# --- Supabase Auth (always pointed at a real project — local Auth not supported) ---
SUPABASE_URL=https://<dev-project>.supabase.co
SUPABASE_JWT_SECRET=<dev-jwt-secret>
NEXT_PUBLIC_SUPABASE_URL=https://<dev-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<dev-publishable-anon-key>

# --- Storage ---
# When storage.local.yml is included it sets STORAGE_PROVIDER=minio and
# MINIO_ENDPOINT=minio:9000. When dropped, the values below are used.
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=https://s3.us-east-2.amazonaws.com
S3_ACCESS_KEY_ID=<aws-access-key>
S3_SECRET_ACCESS_KEY=<aws-secret-key>
S3_BUCKET_NAME=zabt-ai-bucket-dev
S3_PUBLIC_URL=https://s3.us-east-2.amazonaws.com
S3_REGION=us-east-2
MINIO_WEBHOOK_SECRET=local-dev-secret

# --- Transcription ---
# When gpu.local.yml is included it sets TRANSCRIPTION_BACKEND=gpu-local.
# When dropped, the values below are used.
TRANSCRIPTION_BACKEND=runpod
RUNPOD_API_KEY=<runpod-api-key>
RUNPOD_ENDPOINT_ID=<runpod-endpoint-id>
RUNPOD_TIMEOUT=1800

# --- OpenAI / OpenRouter ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=<openrouter-key>
OPENAI_MODEL=google/gemini-3.1-flash-lite-preview

# --- Microsoft Integration (use a localhost redirect URI in your Entra app) ---
MICROSOFT_CLIENT_ID=<entra-app-client-id>
MICROSOFT_CLIENT_SECRET=<entra-app-secret>
MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI defaulted by compose/local.yml to http://localhost:8000/...

# --- Token encryption (Fernet) ---
TOKEN_ENCRYPTION_KEY=<generate-with-Fernet.generate_key>

# --- HuggingFace ---
HF_TOKEN=<hf-token>
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Backend CORS ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Email (Resend) — optional locally ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@zabt.ai

# --- Sentry — optional locally ---
SENTRY_DSN=

# --- Logfire — optional locally ---
LOGFIRE_TOKEN=

# --- Langfuse — optional locally ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Notifications — empty disables them locally ---
NOTIFICATION_PROVIDER=

# --- Bot Worker ---
BOT_WORKER_URL=http://worker-bot:8002
BOT_DISPLAY_NAME=Zabt AI Notetaker
