{
  "expo": {
    "name": "Zabt",
    "slug": "zabt-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zabt",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zabt.mobile",
      "associatedDomains": ["applinks:app.zabt.ai"],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Zabt needs microphone access to record meetings.",
        "UIBackgroundModes": ["audio", "fetch"]
      }
    },
    "android": {
      "package": "com.zabt.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#fafaf8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "app.zabt.ai", "pathPrefix": "/m" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fafaf8",
          "dark": {
            "backgroundColor": "#1a1510"
          }
        }
      ],
      "expo-audio",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "90eecb1a-3fb7-4c02-b97d-3c634e83fdcc"
      }
    },
    "owner": "skajtech"
  }
}
