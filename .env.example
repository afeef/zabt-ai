# ============================================================
# Zabt — Environment Variables
# Copy to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/zabt
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
# POSTGRES_DB=zabt

# --- Redis ---
# (no credentials needed for local dev)

# --- Supabase (Cloud Auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# --- Storage Provider ---
# "minio" (default, local dev) or "s3" (VPS with Cloudflare R2 / AWS S3)
STORAGE_PROVIDER=minio

# --- MinIO (used when STORAGE_PROVIDER=minio) ---
# These have sensible defaults in config.py; override only if needed.
# MINIO_ENDPOINT=minio:9000
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET_NAME=zabt-media
MINIO_WEBHOOK_SECRET=change-me-in-production

# --- AWS S3 (used when STORAGE_PROVIDER=s3) ---
# Required when STORAGE_PROVIDER=s3. Create an IAM user with S3 access.
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=zabt-media
S3_PUBLIC_URL=https://s3.amazonaws.com
S3_REGION=us-east-1

# --- OpenAI / LLM ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-openai-or-openrouter-key
OPENAI_MODEL=google/gemini-3.1-flash-lite-preview

# --- Transcription Backend ---
# "runpod" (default, VPS with RunPod Serverless) or "gpu-local" (local GPU service)
TRANSCRIPTION_BACKEND=runpod

# --- RunPod Serverless (used when TRANSCRIPTION_BACKEND=runpod) ---
RUNPOD_API_KEY=rp_your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-endpoint-id
# RUNPOD_POLL_INTERVAL=5
# RUNPOD_TIMEOUT=1800

# --- GPU Service (used when TRANSCRIPTION_BACKEND=gpu-local) ---
GPU_SERVICE_URL=http://gpu-worker:8001

# --- Microsoft Integration (Entra ID / Graph API) ---
# Register app at https://entra.microsoft.com → App registrations
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://api.yourdomain.com/api/v1/integrations/microsoft/callback

# Fernet key for encrypting OAuth tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key

# --- Bot Worker (Teams meeting bot — headless browser) ---
BOT_WORKER_URL=http://worker-bot:8002
BOT_DISPLAY_NAME=Zabt AI Notetaker

# --- Whisper / Diarization ---
HF_TOKEN=hugging-face-token
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Backend CORS ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com
APP_URL=http://localhost:3000

# --- Sentry APM ---
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production

# --- Logfire Observability ---
LOGFIRE_TOKEN=logfire-token

# --- Langfuse LLM Observability ---
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostHog Analytics ---
POSTHOG_API_KEY=phc_your-posthog-key
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Notification Settings ---
NOTIFICATION_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
