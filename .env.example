# ============================================================================
# zabt.ai — environment configuration
#
#   cp .env.example .env   then fill the values marked  # REQUIRED
#   docker compose up -d
#
# For a first local run you only need to set 4 things:
#   1. SUPABASE_URL + SUPABASE_JWT_SECRET + NEXT_PUBLIC_SUPABASE_* (one free Supabase project)
#   2. OPENAI_API_KEY            (an OpenAI-compatible LLM key, e.g. OpenRouter)
#   3. HF_TOKEN                  (Hugging Face token — accept the pyannote gate; see README)
#   4. leave everything else at its default
#
# DO NOT commit your filled-in .env — it is gitignored.
# ============================================================================

# --- Compose profiles -------------------------------------------------------
# "local" = bundled Postgres + MinIO + GPU worker + web UI (single-machine default).
# Add "bot" for the Teams meeting bot, "vision" for visual breakdown.
# Set empty for the cloud/RunPod split (see docker-compose.cloud.yml).
COMPOSE_PROFILES=local

# --- Database ---------------------------------------------------------------
# Bundled local Postgres (profile "local") credentials:
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=zabt
# REQUIRED. Local default points at the bundled db service. For managed Postgres
# (e.g. Supabase), replace with its asyncpg connection string.
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/zabt

# --- Auth: Supabase ---------------------------------------------------------
# zabt.ai delegates authentication to Supabase (a free project works). Create one at
# https://supabase.com, then copy these from Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co                    # REQUIRED
SUPABASE_JWT_SECRET=your-supabase-jwt-secret                     # REQUIRED (Settings → API → JWT)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co        # REQUIRED (same as SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key             # REQUIRED (publishable/anon key)

# --- URLs -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1                 # browser → API base URL
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000                                   # used in email deep-links
BACKEND_CORS_ORIGINS=http://localhost:3000                      # comma-separated allowed origins

# --- LLM (summarization) ----------------------------------------------------
# Any OpenAI-compatible endpoint: OpenRouter, OpenAI, LM Studio, Ollama, vLLM, etc.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-llm-api-key                                 # REQUIRED
OPENAI_MODEL=google/gemini-3.1-flash-lite-preview

# --- Object storage ---------------------------------------------------------
# "minio" = bundled local MinIO (profile "local"); "s3" = external S3/R2/etc.
STORAGE_PROVIDER=minio
# MinIO (used when STORAGE_PROVIDER=minio):
MINIO_ENDPOINT=minio:9000                                       # in-cluster endpoint
MINIO_PUBLIC_ENDPOINT=http://localhost:9000                     # browser-reachable endpoint (presigned URLs)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=zabt-ai-bucket
MINIO_SECURE=false                                             # true if MinIO/endpoint is served over HTTPS
MINIO_WEBHOOK_SECRET=change-me-in-production                    # shared secret for the MinIO→API upload webhook
# S3 / R2 (used when STORAGE_PROVIDER=s3):
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=zabt-ai-bucket
S3_PUBLIC_URL=
S3_REGION=auto

# --- Transcription ----------------------------------------------------------
# "gpu-local" = bundled worker-gpu (NVIDIA GPU, or CPU via docker-compose.cpu.yml);
# "runpod" = RunPod Serverless (see docker-compose.cloud.yml).
TRANSCRIPTION_BACKEND=gpu-local
GPU_SERVICE_URL=http://worker-gpu:8001
# Whisper model size: tiny|base|small|medium|large-v3 (smaller = faster, less accurate).
# Use base/small for CPU-only runs.
WHISPER_MODEL=large-v3
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1              # gated on HF — accept the terms; see README
MEDASR_MODEL=google/medasr                                      # optional medical ASR model
DIARIZATION_MIN_SPEAKERS=1
DIARIZATION_MAX_SPEAKERS=10
# Hugging Face token — REQUIRED for pyannote diarization. Accept the model gate at
# https://huggingface.co/pyannote/speaker-diarization-3.1 then create a token.
HF_TOKEN=your-hugging-face-token                                # REQUIRED (see README: pyannote gate)
# RunPod (used when TRANSCRIPTION_BACKEND=runpod):
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_POLL_INTERVAL=5
RUNPOD_TIMEOUT=1800

# --- Visual breakdown (optional; profile "vision") --------------------------
VISION_BACKEND=local
VISION_LOCAL_URL=http://zabt-vision-worker:8003
VISION_JUDGE_MODEL=qwen3-vl:8b-thinking
OLLAMA_HOST=http://host.docker.internal:11434                   # Ollama host serving the vision model
VISION_RUNPOD_API_KEY=
VISION_RUNPOD_ENDPOINT_ID=
VISION_POLL_INTERVAL=5
VISION_TIMEOUT=1800

# --- Microsoft / Teams integration (optional) -------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/microsoft/callback
# Fernet key encrypting stored OAuth tokens at rest. REQUIRED if you enable integrations.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Teams meeting bot (optional; profile "bot") ----------------------------
BOT_DISPLAY_NAME=Zabt AI Notetaker
BOT_WORKER_URL=http://worker-bot:8002

# --- Email (Resend, optional) -----------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@zabt.ai

# --- Notifications (optional) -----------------------------------------------
# NOTIFICATION_PROVIDER: "telegram", "multi", or empty to disable.
NOTIFICATION_PROVIDER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Observability (all optional) -------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
LOGFIRE_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Mobile app (optional; only if building the Expo app) -------------------
EXPO_ACCESS_TOKEN=
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
